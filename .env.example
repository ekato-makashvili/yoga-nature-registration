# სერვერის პორტი / Server port
PORT=3000

# საჯარო მისამართი, საიდანაც თქვენი საიტი ხელმისაწვდომია ინტერნეტში.
# TBC-მ უნდა შეძლოს ამ მისამართზე callback-ის გაგზავნა, ამიტომ ლოკალურ
# გარემოში http://localhost სამუშაოდ არ გამოდგება - გამოიყენეთ ngrok
# ან მსგავსი tunneling ხელსაწყო, production-ში კი თქვენი რეალური დომენი.
#
# Public URL where your site is reachable from the internet. TBC needs to
# be able to reach this address for callbacks, so localhost will NOT work
# for real payments - use ngrok (or similar) locally, and your real domain
# in production.
PUBLIC_BASE_URL=http://localhost:3000

# დეველოპერის API გასაღები, მიღებული developers.tbcbank.ge-დან
# (განსხვავებულია client_id/client_secret-გან, რომლებიც merchant-ის
# credential-ებია)
#
# Developer API key from developers.tbcbank.ge (this is separate from the
# merchant client_id/client_secret below)
TBC_API_KEY=your_developer_api_key_here

# TBC E-Commerce მერჩანტის client_id და client_secret, მიღებული
# ecom.tbcpayments.ge-ზე რეგისტრაციის შემდეგ
#
# TBC E-Commerce merchant credentials, obtained after registering at
# ecom.tbcpayments.ge
TBC_CLIENT_ID=your_merchant_client_id_here
TBC_CLIENT_SECRET=your_merchant_client_secret_here
